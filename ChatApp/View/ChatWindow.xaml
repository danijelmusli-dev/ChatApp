<Window x:Class="ChatApp.View.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatApp.View"
        mc:Ignorable="d"
        Title="ChatWindow" Height="500" Width="800">
    <Grid Background="{DynamicResource PrimaryColor}">

        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="6*"/>
            <RowDefinition Height="2.5*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Label x:Name="ChatWithLB" Content="Chat with : " HorizontalAlignment="Left" VerticalAlignment="Center" Margin="00,0,0,0" FontSize="20"/>
            <Label x:Name="ChatterLB"  Content="Nigger" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,0,0" FontSize="20"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="10,0,10,0" Background="{DynamicResource PrimaryMediumColor}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="MessagesPanel" Orientation="Vertical"/>
            </ScrollViewer>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10,0,10,0">
            <TextBox x:Name="MessageTB" Width="600" Height="80" FontSize="20"/>
            <Button x:Name="SendButton" Content="Send" Width="100" Height="50" Margin="40,0,0,0" FontSize="20"
                    Click="SendButton_Click"
                    MouseEnter="Button_MouseEnter"
                    MouseLeave="Button_MouseLeave"/>
        </StackPanel>

    </Grid>
</Window>
