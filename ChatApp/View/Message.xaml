<UserControl x:Class="ChatApp.View.Message"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ChatApp.View"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="400">
    <Border BorderBrush="{DynamicResource SecondaryMediumColor}" BorderThickness="2" CornerRadius="20" >
        <Grid Width="Auto" Height="Auto" Background="{DynamicResource SecondaryColor}">

            <Grid.RowDefinitions>
                <RowDefinition Height="4*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <Label x:Name="MessageLB" Grid.Row="0" Content="Message" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,10,20,10" FontSize="20"/>
            <Label x:Name="TimeLB" Grid.Row="1" Content="Time" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,10,10,0" FontSize="15"/>
            
        </Grid>
    </Border>
    
</UserControl>
