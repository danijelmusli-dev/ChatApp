<UserControl x:Class="ChatApp.View.Connection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ChatApp.View"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="800">
    <Grid Width="800" Height="100" Background="{DynamicResource PrimaryColor}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Label x:Name="ContactLB" Grid.Column="0" Content="Contact : " HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0" FontSize="20"/>

        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Rectangle HorizontalAlignment="Center" Width="30" Height="20" Fill="{DynamicResource SecondaryColor}" Margin="0,0,20,0"/>
            <Rectangle HorizontalAlignment="Center" Width="30" Height="20" Fill="{DynamicResource SecondaryColor}" Margin="0,0,20,0"/>
            <Rectangle HorizontalAlignment="Center" Width="30" Height="20" Fill="{DynamicResource SecondaryColor}" Margin="0,0,20,0"/>
        </StackPanel>

        <Button x:Name="ChatBTN" Grid.Column="2" HorizontalAlignment="Center" Content="Chat" Width="100" Height="60" FontSize="20"></Button>

    </Grid>
</UserControl>
